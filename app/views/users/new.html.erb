<%#= form_tag('/users') do %>
  <%#= label_tag("user[username]", "Username:") %>
  <%#= text_field_tag("user[username]") %>
  <%#= label_tag("user[email]", "Email:") %>
  <%#= email_field_tag("user[email]") %>
  <%#= label_tag("user[password]", "Password:") %>
  <%#= password_field_tag("user[password]") %>
  <%#= submit_tag "Create User" %>
<%# end %>

<%= form_with model: @user do |form| %>
  <%= form.label :username, "Your username:"%>
  <%= form.text_field :username%><br><br>
  <%= form.label :email, "Your email:" %>
  <%= form.email_field :email, placeholder: "example@example.com"%><br><br>
  <%= form.label :password, "Select a password:" %>
  <%= form.password_field :password %><br><br>
  <%= form.submit "Create User" %>
<% end %>
