<form action="/users" method="post" accept-charset="UTF-8" data-turbo="false">
  <input
    type="hidden"
    name="authenticity_token"
    value="<%= form_authenticity_token %>"
  >
  <label for="user_username">Username:</label>
  <input type="text" id="user_username" name="user[username]"><br><br>
  <label for="user_email">Email:</label>
  <input type="email" id="user_email" name="user[email]"><br><br>
  <label for="user_password">Password:</label>
  <input type="password" id="user_password" name="user[password]"><br><br>
  <input type="submit" value="Create">
</form>
